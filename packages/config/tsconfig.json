{
  "compilerOptions": {
    "strict": true,
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "target": "ES2021"
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
